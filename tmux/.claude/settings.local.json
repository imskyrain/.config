{
  "permissions": {
    "allow": [
      "Bash(git config:*)",
      "Bash(git remote set-url:*)",
      "Bash(tmux source-file:*)",
      "Bash(tmux show-options:*)",
      "Bash(if tmux list-sessions)",
      "Bash(then tmux source-file ~/.tmux.conf)",
      "Bash(else echo \"当前没有运行的 tmux 会话，下次启动 tmux 时配置将生效\")",
      "Bash(fi)",
      "Bash(rustc:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebSearch",
      "Bash(curl:*)",
      "Bash(~/.tmux/plugins/tpm/scripts/install_plugins.sh)",
      "Bash(git clone:*)",
      "Bash(chmod:*)",
      "Bash(tmux list-keys:*)",
      "Bash(cat:*)",
      "Bash(/tmp/tmux_temp.conf)",
      "Bash(tmux run-shell:*)",
      "Bash(tmux set:*)",
      "Bash(~/.tmux/plugins/tmux-prefix-highlight/prefix_highlight.tmux)",
      "Bash(tmux show-option:*)",
      "Bash(git checkout:*)",
      "Bash(tmux kill-server:*)",
      "Bash(tmux show-environment:*)",
      "Bash(test:*)",
      "Bash(~/.tmux/plugins/tpm/bin/install_plugins:*)",
      "Bash(tmux display-message:*)",
      "Bash(export TMUX_PLUGIN_MANAGER_PATH=\"$HOME/.tmux/plugins\")",
      "Bash(~/.tmux/plugins/tpm/tpm)",
      "Bash(~/.tmux/plugins/tmux-themepack/themepack.tmux)",
      "Bash(~/.tmux/plugins/tmux-cpu/cpu.tmux)",
      "Bash(~/.tmux/plugins/tmux-battery/battery.tmux)",
      "Bash(~/.tmux/plugins/tpm/bindings/install_plugins)",
      "Bash(tmux set-environment:*)",
      "Bash(tmux list-sessions:*)"
    ],
    "deny": [],
    "ask": []
  }
}
